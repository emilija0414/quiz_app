{
  "quizId": "fitmom",
  "title": "FitMom",
  "intro": {
    "title": "Get back in shape.",
    "image": "/images/fitmomHeroImage.svg",
    "primaryColor": "#AA00FF",
    "buttons": [{ "label": "Start the Quiz", "action": "start" }]
  },
  "questions": [
    {
      "id": "q1",
      "type": "single_choice",
      "text": "What is your primary goal?",
      "options": [
        { "value": "lose_weight", "label": "Lose weight" },
        {
          "value": "improve_body_areas",
          "label": "Improve specific body areas"
        },
        { "value": "gain_muscle", "label": "Gain muscle" },
        { "value": "healthy_habits", "label": "Develop healthy habits" }
      ]
    },
    {
      "id": "q2",
      "type": "multi_choice",
      "text": "Select body areas you would like to improve:",
      "visibleIf": [{ "questionId": "q1", "equals": "improve_body_areas" }],
      "options": [
        {
          "value": "breast",
          "label": "Breast form",
          "image": "/icons/bodyPartIcons/breastFormIcon.svg"
        },
        {
          "value": "arms",
          "label": "Arms",
          "image": "/icons/bodyPartIcons/armIcon.svg"
        },
        {
          "value": "belly",
          "label": "Belly",
          "image": "/icons/bodyPartIcons/bellyIcon.svg"
        },
        {
          "value": "buttocks",
          "label": "Buttocks",
          "image": "/icons/bodyPartIcons/buttocksIcon.svg"
        },
        {
          "value": "legs_thighs",
          "label": "Legs and thighs",
          "image": "/icons/bodyPartIcons/legIcon.svg"
        }
      ]
    },
    {
      "id": "q3",
      "type": "multi_choice",
      "text": "Select types of workouts you like:",
      "options": [
        {
          "value": "flexibility",
          "label": "Flexibility",
          "image": "/icons/workoutIcons/flexibilityIcon.svg"
        },
        {
          "value": "aerobic",
          "label": "Aerobic",
          "image": "/icons/workoutIcons/aerobicIcon.svg"
        },
        {
          "value": "strength",
          "label": "Strength",
          "image": "/icons/workoutIcons/strengthIcon.svg"
        },
        {
          "value": "others",
          "label": "Others",
          "image": "/icons/workoutIcons/othersIcon.svg"
        },
        {
          "value": "no_workouts",
          "label": "I don't like workouts",
          "image": "/icons/workoutIcons/noWorkoutsIcon.svg"
        }
      ]
    },
    {
      "id": "q4",
      "type": "info",
      "text": "Did you know?",
      "image": "/images/info/breastFeeding.svg",
      "description": "Low impact exercises are completely safe during breastfeeding and do not affect the milk supply or taste.",
      "note": "Keep in mind that it only takes 15 minutes of focused daily physical activity to give long-lasting results.",
      "buttons": [{ "label": "OK, let's do it!", "action": "next" }]
    },
    {
      "id": "q5",
      "type": "single_choice",
      "text": "Are you currently breastfeeding?",
      "options": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ]
    },
    {
      "id": "q6",
      "type": "multi_choice",
      "text": "What foods is your breastfed baby sensitive to?",
      "options": [
        {
          "value": "lactose",
          "label": "Lactose",
          "image": "/icons/foodIcons/lactoseIcon.svg"
        },
        {
          "value": "eggs",
          "label": "Eggs",
          "image": "/icons/foodIcons/eggsIcon.svg"
        },
        {
          "value": "nuts",
          "label": "Nuts",
          "image": "/icons/foodIcons/nutsIcon.svg"
        },
        {
          "value": "soy",
          "label": "Soy",
          "image": "/icons/foodIcons/soyIcon.svg"
        },
        {
          "value": "gluten",
          "label": "Gluten",
          "image": "/icons/foodIcons/glutenIcon.svg"
        },
        {
          "value": "fish",
          "label": "Fish",
          "image": "/icons/foodIcons/fishIcon.svg"
        },
        {
          "value": "shellfish",
          "label": "Shellfish",
          "image": "/icons/foodIcons/shellfishIcon.svg"
        },
        { "value": "none", "label": "None of the above" }
      ]
    },
    {
      "id": "q7",
      "type": "number",
      "text": "How young are you?",
      "placeholder": "Age"
    }
  ]
}
