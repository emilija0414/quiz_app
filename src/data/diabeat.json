{
  "quizId": "diabeat",
  "title": "DiaBeat",
  "intro": {
    "title": "Easy-to-follow diabetes plan",
    "image": "/images/diabearHeroImage.svg",
    "primaryColor": "#2C5CEB",
    "secondaryColor": "#FF7040",
    "buttons": [
      {
        "id": "start_quiz_woman",
        "label": "Plan for woman",
        "action": "start"
      },
      { "id": "start_quiz_man", "label": "Plan for man", "action": "start" }
    ]
  },
  "questions": [
    {
      "id": "q1",
      "type": "single_choice",
      "text": "Select your A1C levels",
      "options": [
        { "value": "above_6_4", "label": "> 6.4" },
        { "value": "between_5_7_6_4", "label": "5.7–6.4" },
        { "value": "below_5_6", "label": "< 5.6" },
        { "value": "unknown", "label": "I don’t know" }
      ]
    },
    {
      "id": "q2",
      "type": "single_choice",
      "text": "Have you been diagnosed with diabetes or prediabetes?",
      "options": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ]
    },
    {
      "id": "q3",
      "type": "single_choice",
      "text": "What kind of diabetes have you been diagnosed with?",
      "visibleIf": [{ "questionId": "q2", "equals": "yes" }],
      "options": [
        { "value": "type_1", "label": "Type 1" },
        { "value": "type_2", "label": "Type 2" },
        { "value": "prediabetes", "label": "Prediabetes" },
        { "value": "other", "label": "None of the above" }
      ]
    },
    {
      "id": "q4",
      "type": "info",
      "text": "Did you know?",
      "subtitle": "Small habits can make a big difference.",
      "image": "/images/info/foodPlate.svg",
      "description": "Keep in mind that it only takes 15 minutes of walking each morning to give long-lasting results. Let’s continue with creating your personalized meal plan portfolio!",
      "buttons": [
        { "id": "next_q4", "label": "OK, let's do it!", "action": "next" }
      ]
    },
    {
      "id": "q5",
      "type": "single_choice",
      "text": "Do you have any allergies?",
      "options": [
        { "value": "yes", "label": "Yes" },
        { "value": "no", "label": "No" }
      ]
    },
    {
      "id": "q6",
      "type": "multi_choice",
      "text": "What foods are you allergic to?",
      "visibleIf": [{ "questionId": "q5", "equals": "yes" }],
      "options": [
        {
          "value": "lactose",
          "label": "Lactose",
          "image": "/icons/foodIcons/lactoseIcon.svg"
        },
        {
          "value": "eggs",
          "label": "Eggs",
          "image": "/icons/foodIcons/eggsIcon.svg"
        },
        {
          "value": "nuts",
          "label": "Nuts",
          "image": "/icons/foodIcons/nutsIcon.svg"
        },
        {
          "value": "soy",
          "label": "Soy",
          "image": "/icons/foodIcons/soyIcon.svg"
        },
        {
          "value": "gluten",
          "label": "Gluten",
          "image": "/icons/foodIcons/glutenIcon.svg"
        },
        {
          "value": "fish",
          "label": "Fish",
          "image": "/icons/foodIcons/fishIcon.svg"
        },
        {
          "value": "shellfish",
          "label": "Shellfish",
          "image": "/icons/foodIcons/shellfishIcon.svg"
        },
        { "value": "none", "label": "None of the above" }
      ],
      "buttons": [
        { "id": "continue_q6", "label": "Continue", "action": "next" }
      ]
    },
    {
      "id": "q7",
      "type": "number",
      "text": "How young are you?",
      "placeholder": "Age",
      "buttons": [{ "id": "next_q7", "label": "Next", "action": "next" }]
    }
  ]
}
